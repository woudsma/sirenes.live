#pragma once

// Copy this file to "wifi_credentials.h" (gitignored) and fill in your WiFi.
#define WIFI_STA_SSID "your-wifi-ssid"
#define WIFI_STA_PASS "your-wifi-password"

// --- Cloud archive (VPS) ---
// Where detection audio + events are streamed. Host is bare (no scheme), plain
// HTTP on CLOUD_PORT. CLOUD_DEVICE_TOKEN must match the DEVICE_TOKEN secret on
// the server (see helm-values.yaml). Leave CLOUD_HOST "" to disable uploading.
#define CLOUD_HOST          ""               // e.g. "sirenes.live"
#define CLOUD_PORT          80
#define CLOUD_DEVICE_TOKEN  "your-device-token"
